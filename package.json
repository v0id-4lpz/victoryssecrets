{
  "name": "victoryssecrets",
  "version": "1.0.0",
  "description": "Local secrets & config manager",
  "main": "main.js",
  "scripts": {
    "css": "tailwindcss -i css/app.css -o css/dist.css --minify",
    "css:watch": "tailwindcss -i css/app.css -o css/dist.css --watch",
    "start": "npm run css && electron .",
    "dev": "npm run css && electron . --dev",
    "build": "npm run css && electron-builder",
    "build:mac": "npm run css && electron-builder --mac",
    "build:win": "npm run css && electron-builder --win",
    "build:linux": "npm run css && electron-builder --linux",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "build": {
    "appId": "com.victoryssecrets.app",
    "productName": "VictorysSecrets",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "js/**/*",
      "css/dist.css"
    ],
    "afterPack": "./afterPack.js",
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${arch}-portable.${ext}",
      "category": "public.app-category.developer-tools",
      "identity": null,
      "type": "development",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "artifactName": "${productName}-${version}-setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "appImage": {
      "artifactName": "${productName}-${version}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.2.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "hash-wasm": "^4.12.0"
  }
}
